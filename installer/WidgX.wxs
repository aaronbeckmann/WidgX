<?xml version="1.0" encoding="utf-8"?>
<!--
  WidgX per-user installer (no administrator rights required).
  Installs the self-contained build into %LOCALAPPDATA%\Programs\WidgX, adds Start
  Menu shortcuts (run, check for updates, uninstall), shows a proper install
  wizard, and registers an Add/Remove Programs entry (with Repair/Remove).

  Build:
    wix build installer\WidgX.wxs -arch x64 -ext WixToolset.UI.wixext ^
        -d "PublishDir=...\build" -d "LicenseRtf=...\installer\license.rtf" ^
        -o dist\WidgX.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="WidgX"
           Manufacturer="Aaron Beckmann"
           Version="1.0.0.0"
           UpgradeCode="03ecbcce-07bb-45c2-be1b-1f88842ec421"
           Scope="perUser"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of WidgX is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Install wizard (Welcome / License / Progress / Finish) and, when re-run,
         the maintenance dialog with Repair and Remove (uninstall). -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />

    <Icon Id="AppIcon" SourceFile="$(var.PublishDir)\WidgX.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="ARPHELPLINK" Value="https://github.com/aaronbeckmann/WidgX" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="WidgX" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuDir" Name="WidgX" />
    </StandardDirectory>

    <Feature Id="Main" Title="WidgX" Level="1">
      <!-- Harvest every file from the self-contained publish output. -->
      <Files Include="$(var.PublishDir)\**" Directory="INSTALLFOLDER" />

      <!-- Start Menu shortcuts: run, check for updates, uninstall. -->
      <Component Id="StartMenuShortcuts" Directory="AppProgramMenuDir" Guid="*">
        <Shortcut Id="RunShortcut" Name="WidgX" Description="Desktop widgets"
                  Target="[INSTALLFOLDER]WidgX.exe" WorkingDirectory="INSTALLFOLDER" Icon="AppIcon" />
        <Shortcut Id="UpdateShortcut" Name="Check for Updates"
                  Description="Check GitHub for a newer version of WidgX"
                  Target="[INSTALLFOLDER]WidgX.exe" Arguments="--check-updates"
                  WorkingDirectory="INSTALLFOLDER" Icon="AppIcon" />
        <Shortcut Id="UninstallShortcut" Name="Uninstall WidgX"
                  Description="Remove WidgX"
                  Target="[System64Folder]msiexec.exe" Arguments="/x [ProductCode]" />
        <RemoveFolder Id="RemoveAppProgramMenuDir" Directory="AppProgramMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\WidgX" Name="shortcuts" Type="integer"
                       Value="1" KeyPath="yes" />
      </Component>

      <!-- Remove the install folder on uninstall. -->
      <Component Id="CleanupInstallFolder" Directory="INSTALLFOLDER" Guid="*">
        <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\WidgX" Name="path" Type="string"
                       Value="[INSTALLFOLDER]" KeyPath="yes" />
      </Component>
    </Feature>
  </Package>
</Wix>
