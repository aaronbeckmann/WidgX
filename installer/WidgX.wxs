<?xml version="1.0" encoding="utf-8"?>
<!--
  WidgX per-user installer (no administrator rights required).
  Installs the self-contained build into %LOCALAPPDATA%\Programs\WidgX, adds a
  Start Menu shortcut, and registers an Add/Remove Programs entry.

  Build:  wix build installer\WidgX.wxs -arch x64 -d PublishDir=build -o dist\WidgX.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="WidgX"
           Manufacturer="Aaron Beckmann"
           Version="1.0.0.0"
           UpgradeCode="03ecbcce-07bb-45c2-be1b-1f88842ec421"
           Scope="perUser"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of WidgX is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="$(var.PublishDir)\WidgX.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="WidgX" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />

    <Feature Id="Main" Title="WidgX" Level="1">
      <!-- Harvest every file from the self-contained publish output. -->
      <Files Include="$(var.PublishDir)\**" Directory="INSTALLFOLDER" />

      <!-- Start Menu shortcut (own component with an HKCU keypath, as required
           for a per-user non-advertised shortcut). -->
      <Component Id="StartMenuShortcut" Directory="ProgramMenuFolder" Guid="*">
        <Shortcut Id="WidgXShortcut" Name="WidgX" Description="Desktop widgets"
                  Target="[INSTALLFOLDER]WidgX.exe" WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU" Key="Software\WidgX" Name="shortcut" Type="integer"
                       Value="1" KeyPath="yes" />
      </Component>

      <!-- Remove the install folder on uninstall. -->
      <Component Id="CleanupInstallFolder" Directory="INSTALLFOLDER" Guid="*">
        <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\WidgX" Name="path" Type="string"
                       Value="[INSTALLFOLDER]" KeyPath="yes" />
      </Component>
    </Feature>
  </Package>
</Wix>
