<Window x:Class="WidgX.Designer.DesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WidgX Designer" Width="900" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DesignerSurfaceBrush}"
        TextOptions.TextFormattingMode="Ideal">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <TextBlock Text="Screen:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox x:Name="ScreenPicker" Width="220" DisplayMemberPath="FriendlyName"
                      SelectionChanged="OnScreenChanged" />
        </StackPanel>
        <Border DockPanel.Dock="Bottom" Padding="8" Background="{StaticResource DesignerPanelBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="DiscardButton" Content="Discard" Width="80" Margin="0,0,8,0" Click="OnDiscard" />
                <Button x:Name="ApplyButton" Content="Apply" Width="80" Margin="0,0,8,0" Click="OnApply" />
                <Button x:Name="SaveButton" Content="Save" Width="80" Click="OnSave" />
            </StackPanel>
        </Border>
        <TabControl>
            <TabItem Header="Layout">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Widgets" FontWeight="Bold" Margin="0,0,0,6" />
                        <ListBox x:Name="WidgetPalette" DisplayMemberPath="DisplayName" />
                        <Button x:Name="AddWidgetButton" Content="Add to canvas" Margin="0,6,0,0" Click="OnAddWidget" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="CanvasResolutionLabel" Grid.Row="0"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <!-- The canvas is sized to the monitor's true pixel resolution; the
                             Viewbox scales it to fit so the layout is shown to scale (WYSIWYG).
                             Widget coordinates stay in monitor pixels. -->
                        <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border x:Name="MonitorBezel" Background="{StaticResource DesignerCanvasBrush}"
                                    CornerRadius="6" BorderBrush="{StaticResource ControlBorderBrush}"
                                    BorderThickness="2">
                                <Canvas x:Name="DesignCanvas" Background="{StaticResource DesignerCanvasBrush}"
                                        ClipToBounds="True" />
                            </Border>
                        </Viewbox>
                    </Grid>

                    <StackPanel Grid.Column="2" Margin="8,0,0,0" x:Name="PropertiesPanel" IsEnabled="False">
                        <TextBlock Text="Properties" FontWeight="Bold" Margin="0,0,0,6" />
                        <TextBlock Text="X" /><TextBox x:Name="XBox" />
                        <TextBlock Text="Y" Margin="0,6,0,0" /><TextBox x:Name="YBox" />
                        <TextBlock Text="Width" Margin="0,6,0,0" /><TextBox x:Name="WidthBox" />
                        <TextBlock Text="Height" Margin="0,6,0,0" /><TextBox x:Name="HeightBox" />
                        <TextBlock Text="Opacity (0-1)" Margin="0,6,0,0" /><TextBox x:Name="OpacityBox" />
                        <TextBlock Text="Accent Color" Margin="0,6,0,0" />
                        <Border x:Name="AccentPreview" Height="22" CornerRadius="4" Margin="0,4,0,4"
                                BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1" />
                        <TextBox x:Name="AccentColorBox" TextChanged="OnAccentHexChanged" />
                        <DockPanel Margin="0,6,0,0">
                            <TextBlock Text="R" Width="14" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <Slider x:Name="RSlider" Minimum="0" Maximum="255" SmallChange="1"
                                    ValueChanged="OnRgbSliderChanged" />
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock Text="G" Width="14" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <Slider x:Name="GSlider" Minimum="0" Maximum="255" SmallChange="1"
                                    ValueChanged="OnRgbSliderChanged" />
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock Text="B" Width="14" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <Slider x:Name="BSlider" Minimum="0" Maximum="255" SmallChange="1"
                                    ValueChanged="OnRgbSliderChanged" />
                        </DockPanel>
                        <WrapPanel x:Name="SwatchPanel" Margin="0,8,0,0" />
                        <TextBlock Text="Font Size" Margin="0,6,0,0" /><TextBox x:Name="FontSizeBox" />
                        <StackPanel x:Name="NowPlayingOptions" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock Text="Now Playing" FontWeight="Bold" Margin="0,0,0,4" />
                            <CheckBox x:Name="ShowCoverCheck" Content="Show cover art" />
                            <CheckBox x:Name="SpinCoverCheck" Content="Spin cover (record disk)" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel x:Name="BluetoothOptions" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock Text="Bluetooth device" FontWeight="Bold" Margin="0,0,0,4" />
                            <ComboBox x:Name="BluetoothDevicePicker" DisplayMemberPath="Name" />
                            <CheckBox x:Name="BluetoothAllDevicesCheck" Content="Show all connected devices"
                                      Margin="0,6,0,0" />
                            <Button x:Name="RefreshBluetoothButton" Content="Refresh devices"
                                    Margin="0,6,0,0" Click="OnRefreshBluetooth" />
                        </StackPanel>
                        <StackPanel x:Name="ClockOptions" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock Text="Clock" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBlock Text="Order (top to bottom)" />
                            <ComboBox x:Name="ClockOrder1" Margin="0,4,0,0" />
                            <ComboBox x:Name="ClockOrder2" Margin="0,4,0,0" />
                            <ComboBox x:Name="ClockOrder3" Margin="0,4,0,0" />
                            <TextBlock Text="Time font size" Margin="0,6,0,0" /><TextBox x:Name="ClockTimeSize" />
                            <TextBlock Text="Weekday font size" Margin="0,6,0,0" /><TextBox x:Name="ClockWeekdaySize" />
                            <TextBlock Text="Date font size" Margin="0,6,0,0" /><TextBox x:Name="ClockDateSize" />
                            <TextBlock Text="Date format" Margin="0,6,0,0" />
                            <ComboBox x:Name="ClockDateFormat" DisplayMemberPath="Label" />
                        </StackPanel>
                        <Button x:Name="ApplyPropertiesButton" Content="Apply" Margin="0,10,0,0" Click="OnApplyProperties" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Settings">
                <StackPanel Margin="16">
                    <TextBlock Text="Weather location (city name)" FontWeight="Bold" />
                    <TextBox x:Name="WeatherLocationBox" Width="220" Margin="0,4,0,12" />
                    <Button x:Name="SaveLocationButton" Content="Save location" Width="120" Click="OnSaveLocation" HorizontalAlignment="Left" Margin="0,0,0,4" />
                    <TextBlock x:Name="LocationStatus" Foreground="Gray" Margin="0,0,0,16" TextWrapping="Wrap" />

                    <CheckBox x:Name="AutostartCheckBox" Content="Run WidgX when Windows starts" Checked="OnAutostartChanged" Unchecked="OnAutostartChanged" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
