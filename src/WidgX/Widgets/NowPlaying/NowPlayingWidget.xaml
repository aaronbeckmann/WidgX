<UserControl x:Class="WidgX.Widgets.NowPlaying.NowPlayingWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource WidgetCardStyle}">
        <Grid>
            <!-- Optional animated background that fades between colors sampled from
                 the album cover. Sits behind the content. -->
            <Rectangle x:Name="ColorBackground" RadiusX="8" RadiusY="8" Margin="-4" Visibility="Collapsed">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="ColorStop0" Offset="0" Color="Transparent" />
                        <GradientStop x:Name="ColorStop1" Offset="1" Color="Transparent" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <!-- Cover art, clipped to a circle so it can spin like a record. -->
                    <Grid x:Name="CoverHost" DockPanel.Dock="Left" Width="52" Height="52" Margin="4,4,14,4"
                          VerticalAlignment="Center" Visibility="Collapsed">
                        <Image x:Name="CoverImage" Stretch="Uniform"
                               RenderTransformOrigin="0.5,0.5" CacheMode="BitmapCache">
                            <Image.Clip>
                                <EllipseGeometry x:Name="CoverClip" Center="26,26" RadiusX="26" RadiusY="26" />
                            </Image.Clip>
                            <Image.RenderTransform>
                                <RotateTransform x:Name="CoverRotation" Angle="0" />
                            </Image.RenderTransform>
                        </Image>
                        <!-- Record spindle hole. -->
                        <Ellipse x:Name="Spindle" Width="10" Height="10"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Fill="#22000000" Stroke="#55FFFFFF" StrokeThickness="1" />
                    </Grid>

                    <!-- Single-line title that marquee-scrolls when it doesn't fit.
                         A Canvas lets the text measure at its full width so overflow
                         can be detected; ClipToBounds clips it to the visible area. -->
                    <Canvas x:Name="TextClip" ClipToBounds="True" VerticalAlignment="Center"
                            Height="{Binding ActualHeight, ElementName=NowPlayingText}">
                        <TextBlock x:Name="NowPlayingText" Foreground="White" TextWrapping="NoWrap"
                                   Canvas.Left="0" Canvas.Top="0">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="TextScroll" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Canvas>
                </DockPanel>

                <ProgressBar x:Name="TrackProgress" Grid.Row="1" Height="4" Margin="0,8,0,0"
                             Minimum="0" Maximum="1" Visibility="Collapsed"
                             Background="#33FFFFFF" Foreground="{StaticResource AccentBrush}"
                             BorderThickness="0" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
