<UserControl x:Class="WidgX.Widgets.Weather.WeatherWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource WidgetCardStyle}">
        <StackPanel>
            <!-- Current conditions -->
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="CurrentIcon" FontFamily="Segoe UI Emoji" FontSize="36"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentTemp" FontSize="24" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="CurrentDesc" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- 5-day forecast -->
            <ItemsControl x:Name="ForecastList" Margin="0,10,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Day}" Foreground="White"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Icon}" FontFamily="Segoe UI Emoji"
                                       FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding Range}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
