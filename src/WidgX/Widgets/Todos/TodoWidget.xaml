<UserControl x:Class="WidgX.Widgets.Todos.TodoWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WidgX.Controls">
    <UserControl.Resources>
        <!-- Rounded, accent-filled checkbox with a tick. -->
        <Style x:Key="TodoCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Box" Width="19" Height="19" CornerRadius="5"
                                Background="Transparent" BorderThickness="1.6"
                                BorderBrush="{StaticResource ControlBorderBrush}">
                            <Path x:Name="Tick" Margin="3" Stretch="Uniform"
                                  Data="M 0 5 L 4 9 L 11 1" Stroke="White" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent "add" button. -->
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="30" Height="28" CornerRadius="6"
                                Background="{StaticResource AccentBrush}">
                            <TextBlock Text="+" FontSize="18" Foreground="#0B0B10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle delete button revealed on row hover. -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="20" Height="20" CornerRadius="4" Background="Transparent">
                            <TextBlock x:Name="Glyph" Text="✕" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5534B" />
                                <Setter TargetName="Glyph" Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource WidgetCardStyle}">
        <DockPanel>
            <!-- Quick-add row -->
            <Border DockPanel.Dock="Top" Background="#1AFFFFFF" CornerRadius="8"
                    Padding="6,3" Margin="0,0,0,8">
                <DockPanel>
                    <Button x:Name="AddButton" DockPanel.Dock="Right" Style="{StaticResource AddButtonStyle}"
                            Click="OnAddClick" Margin="6,0,0,0" />
                    <ctrl:DatePickerLite x:Name="NewItemDueDate" DockPanel.Dock="Right" Width="128"
                                         VerticalAlignment="Center" Margin="6,0,0,0" />
                    <Grid VerticalAlignment="Center">
                        <TextBox x:Name="NewItemText" Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center" KeyDown="OnNewItemKeyDown" />
                        <TextBlock Text="Add a task…" Margin="4,0,0,0" IsHitTestVisible="False"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=NewItemText}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Task list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ItemsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="RowRoot" Background="Transparent" CornerRadius="6"
                                    Padding="6,5" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" Style="{StaticResource TodoCheckBoxStyle}"
                                              IsChecked="{Binding IsCompleted}" Checked="OnItemToggled"
                                              Unchecked="OnItemToggled" Tag="{Binding}" />

                                    <TextBlock x:Name="TaskText" Grid.Column="1" Text="{Binding Text}"
                                               Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"
                                               TextTrimming="CharacterEllipsis" />

                                    <Border x:Name="DuePill" Grid.Column="2" Background="#26FFFFFF" CornerRadius="8"
                                            Padding="7,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DueDate, StringFormat='{}{0:MMM d}'}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Border>

                                    <Button x:Name="DeleteBtn" Grid.Column="3" Style="{StaticResource DeleteButtonStyle}"
                                            Click="OnDeleteClick" Tag="{Binding}" Margin="6,0,0,0" Visibility="Hidden" />
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                    <Setter TargetName="TaskText" Property="TextDecorations" Value="Strikethrough" />
                                    <Setter TargetName="TaskText" Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DueDate}" Value="{x:Null}">
                                    <Setter TargetName="DuePill" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <Trigger SourceName="RowRoot" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RowRoot" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                                    <Setter TargetName="DeleteBtn" Property="Visibility" Value="Visible" />
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
