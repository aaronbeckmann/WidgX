<UserControl x:Class="WidgX.Controls.RadialGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="56" MinHeight="56">
    <Grid x:Name="Root" SizeChanged="OnRootSizeChanged">
        <Ellipse x:Name="TrackEllipse" Stroke="#33FFFFFF"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
        <Path x:Name="ValueArc" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="ValueText" Text="0%" HorizontalAlignment="Center"
                       FontWeight="SemiBold" Foreground="#F2F2F5" />
            <TextBlock x:Name="LabelText" Text="" HorizontalAlignment="Center"
                       FontSize="10" Foreground="#A6A6B2" />
        </StackPanel>
    </Grid>
</UserControl>
